# Copy to .env and fill with your Supabase project values.
# Project Settings → API in the Supabase dashboard.
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional: base path for the built site. Defaults to /frontline-tracker/.
# Use "/" for local dev or a custom domain.
# VITE_BASE=/
